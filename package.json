{
  "name": "saas-alerts-mcp",
  "version": "1.0.0",
  "description": "MCP server for the Kaseya SaaS Alerts SaaS security monitoring platform",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "saas-alerts-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "prebuild": "npm run clean",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/http.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "saas-alerts",
    "kaseya",
    "mcp",
    "msp",
    "security",
    "alerts",
    "m365",
    "model-context-protocol"
  ],
  "author": "WYRE Technology",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@wyre-technology/node-saas-alerts": "^1.0.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.4",
    "@types/node": "^25.3.2",
    "@vitest/coverage-v8": "^2.0.0",
    "semantic-release": "^25.0.3",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
